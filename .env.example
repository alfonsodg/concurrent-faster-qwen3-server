# Qwen3-TTS Server Environment Configuration
# Copy to .env and adjust for your deployment

CUDA_VISIBLE_DEVICES=0
MODEL_DIR=models/0.6b-base
MAX_BATCH=8
MAX_WAIT_MS=200
PORT=8090
RUST_LOG=info

